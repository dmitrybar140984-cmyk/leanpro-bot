# Токен от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID канала (со знаком минус, формат -100xxxxxxxxxx)
# Узнать: перешли любое сообщение из канала боту @userinfobot
CHANNEL_ID=-1001234567890

# ID группы комментариев (linked discussion group)
# Если комментарии не подключены — оставь 0 или удали строку
GROUP_ID=-1009876543210

# Telegram user_id администраторов бота (через запятую)
# Узнать свой ID: напиши @userinfobot
ADMIN_IDS=123456789,987654321
